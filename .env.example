# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=mytripcircle

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=https://your-api-domain.com
API_IP_PRIMARY=192.168.x.x
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ─── JWT (générer avec: openssl rand -base64 64) ──────────────────────────────
JWT_SECRET=change-me-before-production
REFRESH_SECRET=change-me-before-production

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
MAIL_USER=noreply@yourdomain.com
MAIL_PASS=your-gmail-app-password

# ─── Google Places API (côté serveur uniquement — ne pas préfixer EXPO_PUBLIC_) ──
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── Google OAuth (Client IDs — préfixe EXPO_PUBLIC_ requis pour accès côté client) ──
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ─── Chiffrement des données PII (openssl rand -hex 32) ───────────────────────
ENCRYPTION_KEY=64-char-hex-key
HMAC_KEY=64-char-hex-key

# ─── IA itinéraires (optionnel) ───────────────────────────────────────────────
GROQ_API_KEY=

# ─── Apple Sign-In (optionnel) ────────────────────────────────────────────────
APPLE_APP_ID=com.yourcompany.mytripcircle
APPLE_TEAM_ID=XXXXXXXXXX

# ─── In-App Purchases (IAP) ───────────────────────────────────────────────────
APPLE_SHARED_SECRET=your-app-store-connect-shared-secret
IAP_SKIP_VALIDATION=false

# ─── Android App Links ────────────────────────────────────────────────────────
# SHA256 du certificat de signature de l'APK — obtenir via : eas credentials
# Format : AA:BB:CC:DD:... (séparateurs deux-points, 32 octets)
ANDROID_SHA256_FINGERPRINT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99