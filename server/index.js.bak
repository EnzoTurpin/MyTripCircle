// Redirection HTTPS vers le deep link (pour que le lien soit cliquable dans les messageries)
app.get("/join/:token", async (req, res) => {
  const { token } = req.params;
  const invitation = await db.collection("invitations").findOne({ token }).catch(() => null);
  if (!invitation) {
    return res.status(404).send(`
      <html><body style="font-family:sans-serif;text-align:center;padding:60px">
        <h2>Invalid or expired link</h2>
        <p>This invitation link is no longer valid.</p>
      </body></html>
    `);
  }
  // Redirige vers le deep link — iOS/Android ouvre l'app si elle est installée
  res.redirect(`mytripcircle://invitation/${token}`);
});

// Créer ou récupérer un lien d'invitation partageable pour un voyage
// Paramètre body optionnel { force: true } pour renouveler le lien (invalide l'ancien)
app.post("/invitations/trip-link/:tripId", requireAuth, async (req, res) => {
  try {
    const inviterId = String(req.user._id);
    const { tripId } = req.params;
    const { force } = req.body;

    const trip = await db.collection("trips").findOne({ _id: new ObjectId(tripId) });
    if (!trip) {
      return res.status(404).json({ error: "Trip not found" });
    }

    const isOwner = trip.ownerId === inviterId;
    const isCollaborator = trip.collaborators.some(
      (collab) => collab.userId === inviterId && collab.permissions.canInvite,
    );

    if (!isOwner && !isCollaborator) {
      return res.status(403).json({ error: "Not authorized to create invitation link" });
    }

    // Supprimer le lien existant si renouvellement forcé
    if (force) {
      await db.collection("invitations").deleteMany({ tripId, inviterId, type: "link" });
    } else {
      // Réutiliser le lien existant si disponible
      const existingLink = await db.collection("invitations").findOne({
        tripId,
        inviterId,
        type: "link",
      });

      if (existingLink) {
        return res.json({
          token: existingLink.token,
          link: `https://mytripcircle-api.enzo-turpin.fr/join/${existingLink.token}`,
        });
      }
    }

    const token = require("crypto").randomBytes(32).toString("hex");
    const invitation = {
      tripId,
      inviterId,
      type: "link",
      status: "pending",
      token,
      permissions: { role: "editor", canEdit: true, canInvite: false, canDelete: false },
      createdAt: new Date(),
      usageCount: 0,
    };

    await db.collection("invitations").insertOne(invitation);

    res.status(201).json({
      token,
      link: `https://mytripcircle-api.enzo-turpin.fr/join/${token}`,
    });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Accepter/Refuser une invitation
app.put("/invitations/:token", async (req, res) => {
  try {
    const { token } = req.params;
    const { action, userId } = req.body; // action: "accept" ou "decline"

    if (!["accept", "decline"].includes(action)) {
      return res.status(400).json({ error: "Invalid action" });
    }

    const invitation = await db.collection("invitations").findOne({ token });
    if (!invitation) {
      return res.status(404).json({ error: "Invitation not found" });
    }

    // Traitement spécial pour les invitations de type lien (réutilisables)
    if (invitation.type === "link") {
      if (action === "decline") {
        return res.json({ success: true, status: "declined", message: "Invitation declined" });
      }

      if (!userId) {
        return res.status(400).json({ error: "userId is required to join via link" });
      }

      const trip = await db.collection("trips").findOne({ _id: new ObjectId(invitation.tripId) });
      if (!trip) {
        return res.status(404).json({ error: "Trip not found" });
      }

      // Vérifier que l'utilisateur n'est pas déjà collaborateur
      const alreadyCollab = trip.collaborators.some((c) => c.userId === userId);
      if (alreadyCollab || trip.ownerId === userId) {
        return res.json({ success: true, status: "accepted", message: "Already a member" });
      }

      await db.collection("invitations").updateOne(
        { _id: invitation._id },
        { $inc: { usageCount: 1 } },
      );

      const linkPerms = invitation.permissions || { role: "editor", canEdit: true, canInvite: false, canDelete: false };
      const collaborator = {
        userId,
        role: linkPerms.role,
        joinedAt: new Date(),
        permissions: linkPerms,
        invitedBy: invitation.inviterId,
      };

      await db
        .collection("trips")
        .updateOne(
          { _id: new ObjectId(invitation.tripId) },
          { $push: { collaborators: collaborator } },
        );

      return res.json({ success: true, status: "accepted", message: "Joined trip successfully" });
    }

    // Invitation directe (email / téléphone)
    if (new Date() > invitation.expiresAt) {
      await db
        .collection("invitations")
        .updateOne({ _id: invitation._id }, { $set: { status: "expired" } });
      return res.status(400).json({ error: "Invitation has expired" });
    }

    if (invitation.status !== "pending") {
      return res.status(400).json({ error: "Invitation already processed" });
    }

    const newStatus = action === "accept" ? "accepted" : "declined";
    const defaultPermissions = { role: "editor", canEdit: true, canInvite: false, canDelete: false };

    if (action === "accept") {
      const permissions = invitation.permissions || defaultPermissions;
      const collaborator = {
        userId: userId || invitation.inviteeEmail,
        role: permissions.role,
        joinedAt: new Date(),
        permissions,
        invitedBy: invitation.inviterId,
      };

      await db
        .collection("trips")
        .updateOne(
          { _id: new ObjectId(invitation.tripId) },
          { $push: { collaborators: collaborator } },
        );
    }

    await db.collection("invitations").updateOne(
      { _id: invitation._id },
      { $set: { status: newStatus, respondedAt: new Date() } },
    );

    res.json({
      success: true,
      status: newStatus,
      message: action === "accept" ? "Invitation accepted" : "Invitation declined",
    });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

