  return `<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">${EMAIL_HEADER}<div style="background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px;">${content}</div></div>`;
}

